{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "run java (with package)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd /d \"${workspaceFolder}\" && javac \"${file}\" && java ${fileDirnameBasename}.${fileBasenameNoExtension} < input.txt > output.txt"
            ],
            "options": {
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}